{
  "name": "jupyterlab-firefox-launcher",
  "version": "0.1.0",
  "description": "JupyterLab extension to launch Firefox in a tab",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "homepage": "https://github.com/vantagecompute/jupyterlab-firefox-launcher",
  "bugs": {
    "url": "https://github.com/vantagecompute/jupyterlab-firefox-launcher/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "James Beedy",
    "email": "james@vantagecompute.ai"
  },
  "files": [
    "static",
    "style"
  ],
  "main": "static/index.js",
  "style": "style/index.css",
  "packageManager": "yarn@1.22.22",
  "repository": {
    "type": "git",
    "url": "https://github.com/vantagecompute/jupyterlab-firefox-launcher.git"
  },
  "scripts": {
    "build": "webpack --mode=production",
    "clean": "rimraf tsconfig.tsbuildinfo static",
    "watch": "webpack --watch --mode=development",
    "watch:webpack": "webpack --watch"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/launcher": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/translation": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/widgets": "^2.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/json-schema": "^7.0.11",
    "@types/react": "^18.0.26",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.7.1",
    "eslint": "^8.36.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "npm-run-all2": "^7.0.1",
    "prettier": "^3.0.0",
    "raw-loader": "^4.0.2",
    "rimraf": "^5.0.1",
    "source-map-loader": "^4.0.1",
    "style-loader": "^3.3.1",
    "stylelint": "^15.10.1",
    "stylelint-config-recommended": "^13.0.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-csstree-validator": "^3.0.0",
    "stylelint-prettier": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "~5.0.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.css"
  ],
  "styleModule": "style/index.css",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "_build": {
      "load": "static/main.js"
    }
  }
}
