{
  "name": "jupyterlab-firefox-launcher",
  "version": "0.7.8",
  "description": "JupyterLab extension to launch Firefox in a tab",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "homepage": "https://github.com/vantagecompute/jupyterlab-firefox-launcher",
  "bugs": {
    "url": "https://github.com/vantagecompute/jupyterlab-firefox-launcher/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "James Beedy",
    "email": "james@vantagecompute.ai"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "jupyterlab_firefox_launcher/labextension/**/*",
    "frontend/src/**/*.{ts,tsx}",
    "tsconfig.json",
    "install.json"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "packageManager": "yarn@1.22.22",
  "repository": {
    "type": "git",
    "url": "https://github.com/vantagecompute/jupyterlab-firefox-launcher.git"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf jupyterlab_firefox_launcher/static tsconfig.tsbuildinfo",
    "clean:all": "rimraf jupyterlab_firefox_launcher/static tsconfig.tsbuildinfo && rimraf jupyterlab_firefox_launcher/labextension",
    "clean:labextension": "rimraf jupyterlab_firefox_launcher/labextension",
    "clean:lib": "rimraf jupyterlab_firefox_launcher/static tsconfig.tsbuildinfo",
    "watch": "run-p watch:src watch:labextension",
    "watch:labextension": "jupyter labextension watch .",
    "watch:src": "tsc -w"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.4.0",
    "@jupyterlab/apputils": "^4.4.0",
    "@jupyterlab/coreutils": "^6.4.0",
    "@jupyterlab/launcher": "^4.4.0",
    "@jupyterlab/translation": "^4.4.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.5",
    "typescript": "~5.0.2"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_firefox_launcher/labextension"
  }
}
